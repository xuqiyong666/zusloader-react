{
  "name": "@xuqiyong666/zusloader-react",
  "version": "0.0.6",
  "description": "zusloader 的 React 适配层，提供控制上下文、Hooks 与宿主集成能力。",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xuqiyong666/zusloader-react.git"
  },
  "license": "ISC",
  "author": "xuqiyong666",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@xuqiyong666/zusloader": "0.0.6",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zustand": ">=4.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@xuqiyong666/zusloader": "file:../zusloader",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "zustand": "^5.0.9"
  }
}